# ============================================================
# AI DIGEST SYSTEM - Configuration
# ============================================================

# ------------------------------------------------------------
# Persona Toggles
# ------------------------------------------------------------
PERSONA_GENAI_NEWS_ENABLED=true
PERSONA_PRODUCT_IDEAS_ENABLED=true

# ------------------------------------------------------------
# LLM Configuration (Ollama)
# ------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3:8b

# ------------------------------------------------------------
# Evaluation Thresholds
# ------------------------------------------------------------
GENAI_NEWS_MIN_RELEVANCE=0.6
PRODUCT_IDEAS_MIN_RELEVANCE=0.5
MAX_ITEMS_TO_EVALUATE=20
MAX_ITEMS_IN_DIGEST=10

# ------------------------------------------------------------
# Delivery (disabled for now - using file output)
# ------------------------------------------------------------
EMAIL_ENABLED=false
TELEGRAM_ENABLED=false

# Email Settings (for later)
# EMAIL_SMTP_HOST=smtp.gmail.com
# EMAIL_SMTP_PORT=587
# EMAIL_FROM=your@email.com
# EMAIL_TO=recipient@email.com
# EMAIL_PASSWORD=your_app_password

# Telegram Settings (for later)
# TELEGRAM_BOT_TOKEN=your_bot_token
# TELEGRAM_CHAT_ID=your_chat_id